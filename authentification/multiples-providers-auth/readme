## 1. Prérequis

- Un projet Next.js 14+ (App Router)
- Node.js 18.18+ installé
- Un compte [Google Cloud Console](https://console.cloud.google.com/) pour l'OAuth Google
- Un compte GitHub pour créer une OAuth App
- Une base de données (PostgreSQL, SQLite, MySQL...) si vous utilisez le login par mot de passe

---

## 2. Installation des dépendances

```bash
# NextAuth (v5, aussi appelé Auth.js)
npm install next-auth@beta

# Hash de mot de passe pour le provider Credentials
npm install bcryptjs
npm install -D @types/bcryptjs

# shadcn/ui (si pas encore initialisé dans le projet)
npx shadcn@latest init

# Composant bouton shadcn
npx shadcn@latest add button
```

---

## 3. Configuration des variables d'environnement

Créez ou complétez votre fichier `.env.local` :

```bash
# Auth.js
AUTH_SECRET=générer_avec_openssl_rand_-base64_33

# Google OAuth
AUTH_GOOGLE_ID=votre_client_id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=votre_client_secret

# GitHub OAuth
AUTH_GITHUB_ID=votre_client_id
AUTH_GITHUB_SECRET=votre_client_secret

# Allowlist des emails autorisés (optionnel)
ALLOWED_EMAILS=alice@example.com,bob@example.com

# Base de données (pour Credentials)
DATABASE_URL=postgresql://user:password@localhost:5432/mabase
```

> **Astuce** : générez `AUTH_SECRET` avec la commande :
> ```bash
> openssl rand -base64 33
> ```

---

## 4. Création des applications OAuth (Google & GitHub)

### Google

1. Rendez-vous sur [Google Cloud Console](https://console.cloud.google.com/apis/credentials)
2. Créez un nouveau projet (ou sélectionnez-en un existant)
3. Menu **APIs & Services > Credentials > Create Credentials > OAuth client ID**
4. Type d'application : **Web application**
5. Ajoutez l'URI de redirection autorisée :
   ```
   http://localhost:3000/api/auth/callback/google
   ```
   (en production, remplacez par votre domaine réel)
6. Copiez le **Client ID** et le **Client Secret** dans `.env.local`

### GitHub

1. Allez sur [GitHub Developer Settings > OAuth Apps](https://github.com/settings/developers)
2. Cliquez sur **New OAuth App**
3. Renseignez :
   - **Homepage URL** : `http://localhost:3000`
   - **Authorization callback URL** :
     ```
     http://localhost:3000/api/auth/callback/github
     ```
4. Générez un **Client Secret** et copiez les deux valeurs dans `.env.local`

---

## 5. Configuration de auth.ts

```typescript
// auth.ts
import NextAuth from "next-auth";
import Google from "next-auth/providers/google";
import GitHub from "next-auth/providers/github";
import Credentials from "next-auth/providers/credentials";
import bcrypt from "bcryptjs";
import { getUserByEmail } from "@/lib/db";

const ALLOWED_EMAILS = (process.env.ALLOWED_EMAILS ?? "")
  .split(",")
  .map((e) => e.trim().toLowerCase())
  .filter(Boolean);

export const { handlers, auth, signIn, signOut } = NextAuth({
  providers: [
    Google,
    GitHub,
    Credentials({
      name: "credentials",
      credentials: {
        email: { label: "Email", type: "email" },
        password: { label: "Mot de passe", type: "password" },
      },
      async authorize(credentials) {
        if (!credentials?.email || !credentials?.password) return null;

        const user = await getUserByEmail(credentials.email as string);
        if (!user || !user.passwordHash) return null;

        const isValid = await bcrypt.compare(
          credentials.password as string,
          user.passwordHash
        );
        if (!isValid) return null;

        return { id: user.id, email: user.email, name: user.name };
      },
    }),
  ],
  callbacks: {
    async signIn({ user, account, profile }) {
      const email = user.email?.toLowerCase();

      // Si une allowlist est définie, on la vérifie
      if (ALLOWED_EMAILS.length > 0 && (!email || !ALLOWED_EMAILS.includes(email))) {
        return false;
      }

      // Vérification email_verified pour les providers OAuth
      if (account?.provider === "google" && profile?.email_verified === false) {
        return false;
      }

      return true;
    },
    async session({ session, token }) {
      if (token.sub && session.user) {
        session.user.id = token.sub;
      }
      return session;
    },
  },
  session: { strategy: "jwt" },
  pages: {
    signIn: "/login",
    error: "/login",
  },
});
```

---

## 6. Mise en place de la base de données (Credentials)

Exemple minimal avec **Prisma** :

```prisma
// prisma/schema.prisma
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
}
```

```typescript
// lib/db.ts
import { prisma } from "@/lib/prisma";

export async function getUserByEmail(email: string) {
  return prisma.user.findUnique({ where: { email } });
}

export async function createUser(email: string, passwordHash: string, name?: string) {
  return prisma.user.create({ data: { email, passwordHash, name } });
}
```

N'oubliez pas de lancer la migration :

```bash
npx prisma migrate dev --name init
```

---

## 7. Route Handler API

```typescript
// app/api/auth/[...nextauth]/route.ts
import { handlers } from "@/auth";

export const { GET, POST } = handlers;
```

